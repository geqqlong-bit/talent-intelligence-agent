{
  "name": "tia-openclaw-plugin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Talent Intelligence Agent delivery for OpenClaw with PostgreSQL-backed tools, HTTP APIs, and dashboard.",
  "main": "index.js",
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "providers": [
      "tia"
    ]
  },
  "scripts": {
    "start": "tsx server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:tia": "vitest run",
    "test:tia:e2e": "tsx tests/tia-http-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "dependencies": {
    "pg": "^8.12.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
