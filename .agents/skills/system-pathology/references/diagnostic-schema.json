{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SystemPathologyDiagnosticReport",
  "description": "Structured output schema for system pathology analyses. Enables tracking, comparison, and longitudinal monitoring across analyses.",
  "type": "object",
  "required": ["metadata", "cartography", "dimensions", "cross_dimensional", "risk_nodes", "scenarios", "prescriptions"],
  "properties": {

    "metadata": {
      "type": "object",
      "required": ["system_name", "system_type", "analysis_date", "analyst_confidence", "information_sources"],
      "properties": {
        "system_name": { "type": "string", "description": "Full name of the system analyzed" },
        "system_type": {
          "type": "string",
          "enum": ["public_company", "private_company", "government", "dao", "platform_ecosystem", "industry_market", "ngo", "other"]
        },
        "analysis_date": { "type": "string", "format": "date" },
        "presenting_symptom": { "type": "string", "description": "Why was this analysis triggered?" },
        "analyst_confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Overall confidence in the analysis given available information"
        },
        "information_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string" },
              "tier": { "type": "integer", "minimum": 1, "maximum": 4 },
              "recency": { "type": "string", "enum": ["current", "recent_12mo", "historical"] }
            }
          }
        },
        "information_gaps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Key information that couldn't be obtained and limits confidence"
        }
      }
    },

    "cartography": {
      "type": "object",
      "description": "Structural map of the system before diagnosis",
      "properties": {
        "key_agents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "stated_objective": { "type": "string" },
              "revealed_preference": { "type": "string" },
              "alignment_gap": { "type": "string", "enum": ["none", "minor", "significant", "severe"] }
            }
          }
        },
        "formal_rules": { "type": "array", "items": { "type": "string" } },
        "informal_rules": { "type": "array", "items": { "type": "string" } },
        "key_resource_flows": { "type": "array", "items": { "type": "string" } },
        "system_phase": {
          "type": "string",
          "enum": ["formation", "growth", "maturity", "decline", "crisis", "transformation", "unknown"]
        },
        "critical_path_dependencies": { "type": "array", "items": { "type": "string" } }
      }
    },

    "dimensions": {
      "type": "object",
      "description": "Six-dimensional diagnostic scores and findings",
      "required": ["d1_boundary", "d2_incentive", "d3_information", "d4_temporal", "d5_legitimacy", "d6_coupling"],
      "properties": {

        "d1_boundary": {
          "$ref": "#/definitions/dimension",
          "properties": {
            "hard_constraints": { "type": "array", "items": { "type": "string" } },
            "soft_constraint_health": { "type": "string", "enum": ["strong", "degrading", "collapsed"] },
            "transaction_cost_trend": { "type": "string", "enum": ["decreasing", "stable", "increasing", "non_linear"] },
            "pathology_patterns": { "type": "array", "items": { "type": "string" } }
          }
        },

        "d2_incentive": {
          "$ref": "#/definitions/dimension",
          "properties": {
            "incentive_compatibility_gaps": { "type": "array", "items": { "type": "string" } },
            "game_type": { "type": "string", "enum": ["positive_sum", "mixed_sum", "zero_sum", "tragedy_commons"] },
            "principal_agent_layers": { "type": "integer" },
            "pathology_patterns": { "type": "array", "items": { "type": "string" } }
          }
        },

        "d3_information": {
          "$ref": "#/definitions/dimension",
          "properties": {
            "signal_fidelity": { "type": "string", "enum": ["high", "moderate", "distorted", "fabricated"] },
            "dangerous_feedback_loops": { "type": "array", "items": { "type": "string" } },
            "broken_feedback_loops": { "type": "array", "items": { "type": "string" } },
            "decision_latency": { "type": "string", "enum": ["fast", "adequate", "slow", "gridlocked"] },
            "pathology_patterns": { "type": "array", "items": { "type": "string" } }
          }
        },

        "d4_temporal": {
          "$ref": "#/definitions/dimension",
          "properties": {
            "entropy_balance": { "type": "string", "enum": ["net_negentropy", "balanced", "net_entropy", "consuming_seed_corn"] },
            "game_philosophy": { "type": "string", "enum": ["infinite", "mixed", "finite", "terminal"] },
            "optionality_level": { "type": "string", "enum": ["high", "moderate", "low", "locked_in"] },
            "antifragility": { "type": "string", "enum": ["antifragile", "resilient", "fragile"] },
            "pathology_patterns": { "type": "array", "items": { "type": "string" } }
          }
        },

        "d5_legitimacy": {
          "$ref": "#/definitions/dimension",
          "properties": {
            "narrative_reality_gap": { "type": "string", "enum": ["minimal", "moderate", "significant", "inverted"] },
            "internal_cynicism_level": { "type": "string", "enum": ["low", "moderate", "high", "epidemic"] },
            "external_legitimacy_trend": { "type": "string", "enum": ["growing", "stable", "eroding", "collapsed"] },
            "identity_coherence": { "type": "string", "enum": ["strong", "intact", "strained", "fragmented"] },
            "pathology_patterns": { "type": "array", "items": { "type": "string" } }
          }
        },

        "d6_coupling": {
          "$ref": "#/definitions/dimension",
          "properties": {
            "internal_coupling": { "type": "string", "enum": ["appropriately_loose", "appropriately_tight", "over_tight", "under_tight"] },
            "critical_single_points_of_failure": { "type": "array", "items": { "type": "string" } },
            "buffer_adequacy": { "type": "string", "enum": ["strong", "adequate", "thin", "none"] },
            "cascade_risk": { "type": "string", "enum": ["low", "moderate", "high", "inevitable"] },
            "pathology_patterns": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "cross_dimensional": {
      "type": "object",
      "properties": {
        "vicious_cycles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "dimensions_involved": { "type": "array", "items": { "type": "string" } },
              "mechanism": { "type": "string" },
              "severity": { "type": "string", "enum": ["developing", "established", "accelerating"] }
            }
          }
        },
        "virtuous_cycles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "dimensions_involved": { "type": "array", "items": { "type": "string" } },
              "mechanism": { "type": "string" }
            }
          }
        },
        "compensating_effects": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Where strength in one dimension offsets weakness in another"
        },
        "highest_leverage_points": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Meadows-style leverage points where small changes have large system effects"
        }
      }
    },

    "risk_nodes": {
      "type": "array",
      "description": "1-3 most critical failure points",
      "items": {
        "type": "object",
        "required": ["name", "dimension_primary", "failure_cascade", "time_horizon", "trigger"],
        "properties": {
          "name": { "type": "string", "description": "Precise name — specific enough to act on" },
          "dimension_primary": { "type": "string" },
          "dimensions_secondary": { "type": "array", "items": { "type": "string" } },
          "failure_cascade": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Ordered sequence of events if this node fails"
          },
          "time_horizon": { "type": "string", "enum": ["immediate_0-3mo", "near_term_3-12mo", "medium_term_1-3yr", "long_term_3yr+"] },
          "trigger": { "type": "string", "description": "What event/condition could precipitate failure" },
          "severity": { "type": "string", "enum": ["existential", "severe", "significant", "moderate"] }
        }
      }
    },

    "overall_health": {
      "type": "object",
      "properties": {
        "composite_score": { "type": "number", "minimum": 1, "maximum": 5 },
        "trajectory": { "type": "string", "enum": ["improving", "stable", "deteriorating", "accelerating_decline"] },
        "system_archetype": {
          "type": "string",
          "description": "One-phrase characterization: 'mature institution in slow decay', 'growth-stage entity hitting scaling limits', etc."
        }
      }
    },

    "scenarios": {
      "type": "array",
      "description": "Natural evolution paths if no significant intervention",
      "items": {
        "type": "object",
        "required": ["name", "type", "probability", "description", "key_conditions"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["heat_death", "violent_bifurcation", "phase_transition", "recovery", "other"] },
          "probability": { "type": "number", "minimum": 0, "maximum": 1 },
          "time_horizon": { "type": "string" },
          "description": { "type": "string" },
          "key_conditions": { "type": "array", "items": { "type": "string" } },
          "early_warning_signals": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "prescriptions": {
      "type": "array",
      "description": "3-5 high-leverage interventions",
      "items": {
        "type": "object",
        "required": ["title", "target_dimension", "mechanism", "resistance", "second_order_effects"],
        "properties": {
          "title": { "type": "string" },
          "target_dimension": { "type": "string" },
          "target_pathology": { "type": "string" },
          "mechanism": { "type": "string", "description": "Why this works, not just what to do" },
          "specific_actions": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Concrete enough to execute on Monday morning"
          },
          "resistance": { "type": "string", "description": "Who will oppose this and why" },
          "second_order_effects": { "type": "array", "items": { "type": "string" } },
          "impact": { "type": "string", "enum": ["transformative", "high", "medium", "low"] },
          "feasibility": { "type": "string", "enum": ["high", "medium", "low", "requires_external_shock"] },
          "urgency": { "type": "string", "enum": ["immediate", "near_term", "medium_term"] }
        }
      }
    },

    "monitoring_dashboard": {
      "type": "array",
      "description": "Leading indicators for ongoing health tracking",
      "items": {
        "type": "object",
        "required": ["indicator", "dimension", "how_to_measure", "danger_threshold", "health_threshold"],
        "properties": {
          "indicator": { "type": "string" },
          "dimension": { "type": "string" },
          "how_to_measure": { "type": "string" },
          "measurement_frequency": { "type": "string" },
          "danger_threshold": { "type": "string" },
          "health_threshold": { "type": "string" },
          "leading_or_lagging": { "type": "string", "enum": ["leading", "coincident", "lagging"] }
        }
      }
    }

  },

  "definitions": {
    "dimension": {
      "type": "object",
      "required": ["score", "trajectory", "key_findings", "evidence"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 1,
          "maximum": 5,
          "description": "Health score calibrated against scoring-calibration.md anchor cases"
        },
        "trajectory": {
          "type": "string",
          "enum": ["improving", "stable", "deteriorating"],
          "description": "Direction of travel over last 12 months"
        },
        "key_findings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "2-3 most important observations for this dimension"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Observable facts or data points supporting the score"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Confidence in this dimension's score given available data"
        }
      }
    }
  }
}
