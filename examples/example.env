# Recruiting workflow backend
export TALENT_INTEL_BACKEND_URL="http://127.0.0.1:8788"

# CLI-side convenience vars used by skill/talent-intelligence-agent/scripts/talent-intelligence-cli.mjs
export TALENT_INTEL_LLM_BASE_URL="http://127.0.0.1:8999/v1"
export TALENT_INTEL_LLM_API_KEY="test-key"
export TALENT_INTEL_DEFAULT_MODEL="bailian/qwen3.5-plus"

# Server-side remote runner vars used by server/app/remote-openai.mjs
# Remote calls happen only when the request explicitly selects the remote runner
# AND outbound execution is enabled.
export TALENT_INTEL_ENABLE_REMOTE_RUNNER="1"
export TALENT_INTEL_REMOTE_BASE_URL="http://127.0.0.1:8999/v1"
export TALENT_INTEL_REMOTE_API_KEY="test-key"
export TALENT_INTEL_REMOTE_PATH="/chat/completions"
# optional
# export TALENT_INTEL_REMOTE_ORG="org_xxx"
# export TALENT_INTEL_REMOTE_PROJECT="proj_xxx"

# Optional tuning
export TALENT_INTEL_TEMPERATURE="0.4"
export TALENT_INTEL_MAX_TOKENS="5000"
export TALENT_INTEL_TIMEOUT_MS="120000"
